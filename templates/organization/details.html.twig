{% extends "_layouts/blank.html.twig" %}

{% block title %}{{ organization.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/components/entity-header.css') }}">
{% endblock %}

{% block content %}
    <section class="entity-section">
        {% include "_components/entity-header.html.twig" with {
            id: organization.id,
            name: organization.name,
            image: organization.image|default('img/default-image.png'),
            coverImage: organization.coverImage|default('img/banner-default-white.jpeg'),
            icon: 'place',
            label: organization.type|default('available_type'|trans),
            longBio: organization.description,
            actions: 'organization/_partials/details/actions.html.twig',
            tabs: 'organization/_partials/details/profile-tabs.html.twig',
            breadcrumbs: [
                {text: 'home'|trans, path: path('web_home_homepage')},
                {text: 'organizations'|trans, path: path('web_organization_list')},
                {text: organization.name, path: path('web_organization_getOne', {id: organization.id})}
            ]
        } only %}
    </section>

    <section class="profile-entity-wrapper">
        <div>
            {% include 'organization/_partials/details/profile-content-tabs.html.twig' %}
        </div>
    </section>
{% endblock %}

{% block footer %}{% endblock %}
{% block extra_javascripts %}
    <script type="module" src="{{ asset('js/_components/copy-id.js') }}"></script>
{% endblock %}
