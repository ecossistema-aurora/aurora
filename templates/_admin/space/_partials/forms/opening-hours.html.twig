<div class="container-fluid opening-hours p-0" id="opening-hours-container">
    <div class="row g-2 g-md-3 align-items-end opening-hours-row">
        <div class="col-md-6">
            <label class="form-label">{{ 'week_days' | trans }}</label>
            <select class="form-select week_days">
                <option value="" disabled selected>{{ 'select' | trans }}</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">{{ 'opens_at' | trans }}</label>
            <input type="time" class="form-control opens_at" placeholder="00:00">
        </div>

        <div class="col-md-3">
            <label class="form-label">{{ 'closes_at' | trans }}</label>
            <input type="time" class="form-control closes_at" placeholder="00:00">
        </div>
    </div>

    <div class="row mt-4">
        <div class="col">
            <a href="#" class="text-primary fw-bold text-decoration-none" id="add-opening-hours">
                <i class="iconify fs-3" data-icon="gridicons:add"></i>
                {{ 'add_opening_hours' | trans }}
            </a>
        </div>
    </div>
</div>
