<div class="d-flex flex-column flex-lg-row justify-content-between align-items-stretch align-items-lg-center gap-3 mb-4">
    {% set now = date('now') %}
    {% set month = now.format('F')|trans %}
    <h2 class="mb-0">{{ 'events_month_year'| trans({'{month}': month, '{year}': now.format('Y')}) }}</h2>
    {% set sublist_tabs = [
        {
            'id': 'list',
            'title': 'list' | trans,
            'icon': 'list',
        },
        {
            'id': 'cards',
            'title': 'Cards',
            'icon': 'view_module',
        },
        {
            'id': 'calendar',
            'title': 'calendar' | trans,
            'icon': 'calendar_today',
        },
    ] %}

    <div>
        {% include '_components/_sublist/see-how.html.twig' with { 'sublist_tabs': sublist_tabs } %}
    </div>
</div>

{% set sublist_contents = [
    {
        'id': 'list',
        'content': include('_components/_sublist/event/list.html.twig')
    },
    {
        'id': 'cards',
        'content': include('_components/_sublist/event/cards.html.twig')
    },
] %}

{% include '_components/_sublist/content-tabs.html.twig' with { 'sublist_contents': sublist_contents } %}
