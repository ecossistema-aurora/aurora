<div class="d-flex align-content-center justify-content-between">
    <p class="total-events">{{ totalEvents }} {{ 'view.event.quantity.total' | trans }}</p>
    {% include '_components/order-select.html.twig' %}
</div>

{% for event in events %}
    <div class="card event-card mt-3">
        <div class="card-body row">

            <div class="col-12 col-sm-8 col-md-9">
                <div class="d-flex align-items-center">
                    <img src="{{ event.image ? asset(event.image) : asset('img/home-events.png') }}"
                         alt="{{ event.name }}" class="rounded-circle event-img">
                    <div class="ms-3">
                        <h5 class="event-name fw-bold">{{ event.name }}</h5>
                        <p class="text-dark mb-0">{{ event.subtitle ?? 'no_subtitle' | trans }}</p>
                    </div>
                </div>

                <div class="d-flex flex-column gap-2 mt-3">
                    <p class="d-flex align-items-center gap-2 mb-0">
                        <i class="material-icons text-primary">event</i>
                        <strong class="text-dark">
                            {% set nextOccurrence = event.eventSchedules|sort((a, b) => a.startHour <=> b.startHour)|find(o => o.startHour > "now"|date) %}
                            {{ nextOccurrence ? nextOccurrence.startHour|date('d/m/Y - H:i') : 'view.event.not_set_datetime' | trans }}
                        </strong>
                    </p>

                    <p class="d-flex align-items-center gap-2 mb-0">
                        <i class="material-icons text-primary">location_on</i>
                        <span class="fw-bold text-dark">{{ event.space ? event.space.name : 'event.card.location' | trans }}</span>
                    </p>
                </div>

                <p class="event-languages mt-4">
                    <strong class="text-dark">{{ 'language' | trans }} ({{ event.tags|length }}):</strong>
                    {% for tag in event.tags %}
                        <span class="badge bg-light text-dark px-3 py-2">{{ tag.name }}</span>
                    {% else %}
                        <span class="text-primary">{{ 'no_languages' | trans }}</span>
                    {% endfor %}
                </p>

                <div class="event-details d-flex flex-wrap gap-3">
                    <p class="d-flex align-items-center gap-2 mb-0">
                        <i class="material-icons text-primary">monetization_on</i>
                        <strong class="text-dark">{{ 'entry_fee' | trans }}:</strong>
                        <span class="text-dark">{{ event.free ? 'free' | trans : 'paid' | trans }}</span>
                    </p>

                    <p class="d-flex align-items-center gap-2 mb-0">
                        <i class="material-icons text-primary">people</i>
                        <strong class="text-dark">{{ 'participants' | trans }}:</strong>
                        <span class="text-dark">{{ event.maxCapacity ?? 'participants' | trans }}</span>
                    </p>
                </div>

                <div class="entity-seals mt-3">
                    <strong class="text-dark">{{ 'seals' | trans }}:</strong>
                    {% for tag in event.tags %}
                        <span class="seal-entity">{{ tag.name }}</span>
                    {% else %}
                        <span class="seal-entity">{{ 'no_seals' | trans }}</span>
                    {% endfor %}
                </div>
            </div>

            <div class="col-12 col-sm-4 col-md-3 d-flex flex-column justify-content-end">
                <button class="btn btn-outline-primary mb-2" data-id="{{ event.id }}">
                    {{ 'copy_id' | trans }}
                </button>

                <a href="{{ path('web_event_show', {id: event.id}) }}" class="btn btn-primary">
                    {{ 'view.event.access' | trans }}
                </a>
            </div>

        </div>
    </div>
{% else %}
    <p class="text-center text-muted mt-4">{{ 'no_events_available' | trans }}</p>
{% endfor %}
